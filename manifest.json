{
  "manifest_version": 2,
  "name": "Tab Auto Closer",
  "version": "1.0.0",
  "description": "Automatically closes tabs that have been open for more than 12 hours, regardless of which workspace they're in",
  "author": "nthnbch",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "contextualIdentities",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["browser-polyfill.min.js", "background/background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg"
    },
    "default_title": "Tab Auto Closer",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabautocloser@nthnbch.com"
    }
  }
}