{
  "manifest_version": 2,
  "name": "FFTabClose",
  "version": "4.0.0",
  "description": "Auto-ferme les onglets après un délai configurable",
  "author": "nthnbch",
  
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  
  "background": {
    "scripts": ["background/background-safe.js"],
    "persistent": true
  },
  
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg"
    },
    "default_title": "FFTabClose",
    "default_popup": "popup/popup-safe.html"
  },
  
  "browser_specific_settings": {
    "gecko": {
      "id": "fftabclose@nthnbch.com",
      "strict_min_version": "109.0"
    }
  }
}